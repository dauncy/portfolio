{
  "compilerOptions": {
    "importHelpers": true,
    "moduleResolution": "node",
    "module": "esNext",
    "target": "es2022",
    "allowJs": true,
    "declaration": true,
    "sourceMap": true,
    "noImplicitAny": false,
    "noImplicitReturns": false,
    "emitDecoratorMetadata": true,
    "noImplicitThis": true,
    "noUnusedLocals": false,
    "strict": true,
    "experimentalDecorators": true,
    "exactOptionalPropertyTypes": true,
    "strictFunctionTypes": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["vite/client"],
    "lib": ["es6", "dom", "es2015.promise", "es2015.collection", "es2015.iterable"],
    "outDir": "dist",
    "typeRoots": [],
    "paths": {
      "src/*": ["./src/*"]
    }
  },
  "include": ["./src/**/*", "./scripts/**/*"],
}
